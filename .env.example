# NeuronShell - SSH Cluster Dashboard
# Copy this file to .env and fill in your values.

# JWT secret for session tokens (generate a random 64-char hex string)
JWT_SECRET=change_me_to_a_random_secret_at_least_32_chars

# App users — format: user1:bcrypt_hash,user2:bcrypt_hash
# Generate a hash: bunx bcryptjs <password>
# Example: admin:$2a$10$...
APP_USERS=admin:$2a$10$examplehashhere

# Optional: session duration in hours (default: 24)
SESSION_HOURS=24
